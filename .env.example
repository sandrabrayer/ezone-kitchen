# ezone-kitchen environment (copy to .env for local dev; set these in Railway
# for production). NONE of these values are committed to the repo.

# The Google Apps Script Web App /exec URL (POST endpoint bound to the Sheet).
# Server-side only — never exposed to the browser.
APPS_SCRIPT_URL=https://script.google.com/macros/s/XXXXXXXX/exec

# Shared secret between THIS server and the Apps Script. Must match the
# SHARED_SECRET Script Property on the Apps Script (Project Settings → Script
# Properties). Server-side only. Generate a random value.
APPS_SCRIPT_SECRET=replace-with-a-random-shared-secret

# --- Access codes (no user accounts; the code alone decides the role) ---
# Codes are WORDS (letters), matched case-insensitively and ignoring surrounding
# whitespace: "ramot", "RAMOT", and " Ramot " all match a stored "RAMOT".

# ADMIN code: grants ALL houses + the budget admin (all-houses) view.
ADMIN_PIN=ezone-admin

# Per-house COOK codes: a JSON object mapping each cook code (a word) to the ONE
# house id that code may open. A cook code opens only its own house (menu,
# headcount, stock, shopping list, and that house's budget) — never another
# house, and never the all-houses admin view.
#
# House ids are the seeded, human-readable ids (or copy one from the admin
# all-houses view). Update this whenever you add or remove houses. Each code must
# differ (case-insensitively) from ADMIN_PIN and from the other cook codes.
# Leave empty until you want to hand out cook codes.
#   COOK_PINS={"ramot":"ramot-hashavim","pardes":"pardes"}
COOK_PINS={}

# HMAC session secret — MUST be at least 32 characters. Generate a random one,
# e.g.  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-with-a-random-string-at-least-32-chars

# Optional: session lifetime in days (default 7).
SESSION_DAYS=7
